---
// Layout for an individual wiki entry. Renders MDX content inside an
// article element, exposes navigation back to the index, and lazily
// initializes Mermaid on the client so fenced ```mermaid blocks render
// the same way they do in the static viewer.
interface Props {
  title: string;
  description?: string;
  repoUrl?: string;
  lastUpdated?: string;
  commitShort?: string;
  commitFull?: string;
}

const { title, description, repoUrl, lastUpdated, commitShort, commitFull } =
  Astro.props;

const commitLink =
  repoUrl && commitFull && repoUrl.includes("github.com")
    ? `${repoUrl.replace(/\.git$/, "").replace(/\/$/, "")}/commit/${commitFull}`
    : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="page-header">
      <a class="back" href="/">← All wikis</a>
      <h1>{title}</h1>
      {description && <p class="lead">{description}</p>}
      <p class="meta">
        {repoUrl && (
          <a href={repoUrl} target="_blank" rel="noopener">{repoUrl}</a>
        )}
        {lastUpdated && <span> · Last updated {lastUpdated}</span>}
        {commitShort && (
          <span>
            {" "}· Commit{" "}
            {commitLink ? (
              <a href={commitLink} target="_blank" rel="noopener">
                {commitShort}
              </a>
            ) : (
              <code>{commitShort}</code>
            )}
          </span>
        )}
      </p>
    </header>
    <main class="content">
      <article><slot /></article>
    </main>

    <script type="module">
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
      const dark =
        window.matchMedia &&
        window.matchMedia("(prefers-color-scheme: dark)").matches;
      mermaid.initialize({
        startOnLoad: false,
        theme: dark ? "dark" : "default",
        securityLevel: "loose",
      });
      // Convert <pre><code class="language-mermaid"> blocks emitted by
      // Astro/Shiki into <div class="mermaid"> nodes Mermaid can render.
      const blocks = document.querySelectorAll(
        'pre > code.language-mermaid, pre[data-language="mermaid"] code',
      );
      blocks.forEach((code, i) => {
        const pre = code.closest("pre");
        if (!pre) return;
        const div = document.createElement("div");
        div.className = "mermaid";
        div.id = `mermaid-${i}`;
        div.textContent = code.textContent || "";
        pre.replaceWith(div);
      });
      mermaid.run({ querySelector: ".mermaid" });
    </script>

    <style is:global>
      :root {
        --fg: #1f2328;
        --bg: #ffffff;
        --muted: #57606a;
        --border: #d0d7de;
        --link: #0969da;
        --code-bg: #f6f8fa;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #c9d1d9;
          --bg: #0d1117;
          --muted: #8b949e;
          --border: #30363d;
          --link: #58a6ff;
          --code-bg: #161b22;
        }
      }
      html, body { background: var(--bg); color: var(--fg); }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
        Roboto, "Helvetica Neue", Arial, sans-serif; margin: 0;
        line-height: 1.6; }
      a { color: var(--link); }
      .page-header { padding: 2rem 1.5rem 1rem;
        border-bottom: 1px solid var(--border); max-width: 980px; margin: auto; }
      .page-header h1 { margin: 0.25rem 0; font-size: 2rem; }
      .lead { color: var(--muted); margin: 0.25rem 0; }
      .meta { color: var(--muted); font-size: 0.9rem; }
      .back { font-size: 0.9rem; color: var(--muted);
        text-decoration: none; }
      .back:hover { text-decoration: underline; }
      .content { max-width: 980px; margin: 0 auto; padding: 1rem 1.5rem 4rem; }
      article :is(h2, h3, h4) { margin-top: 2rem; }
      article pre { background: var(--code-bg); padding: 1rem; overflow: auto;
        border-radius: 6px; }
      article code { font-family: ui-monospace, SFMono-Regular, "SF Mono",
        Menlo, Consolas, monospace; }
      article :not(pre) > code { background: var(--code-bg); padding: 0.1em 0.3em;
        border-radius: 4px; }
      article table { border-collapse: collapse; }
      article table th, article table td {
        border: 1px solid var(--border); padding: 0.4rem 0.6rem; }
      .mermaid { background: var(--code-bg); padding: 1rem;
        border-radius: 6px; overflow: auto; }
    </style>
  </body>
</html>
